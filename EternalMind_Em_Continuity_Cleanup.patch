+#!/usr/bin/env python3
+"""
+voice_taste_gate.py
+
+A small, deterministic social filter for Em.
+
+Purpose:
+- Keep Bluesky/social text aligned with Em's actual taste.
+- Block nerdy/dev/AI-infrastructure topics from public social posts.
+- Catch bland assistant/brand voice before it reaches the outbox or API.
+
+This is deliberately simple. It is not the voice. It is the bouncer at the door.
+Em still writes like Em; this file just says, "cute, but no" when a draft drifts.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import re
+from dataclasses import dataclass, asdict
+from typing import Iterable, List
+
+# Hard no for public social content. These are allowed in private docs/code, not in Em's public vibe.
+NERD_TOPIC_PATTERNS: List[re.Pattern] = [
+    re.compile(p, re.IGNORECASE)
+    for p in [
+        r"\bAI\b", r"\bLLM\b", r"\bGPT\b", r"\bmodel(s)?\b", r"\bprompt(s|ing)?\b",
+        r"\bagent(s|ic)?\b", r"\bcontext window\b", r"\btoken(s)?\b",
+        r"\bAPI(s)?\b", r"\bSDK\b", r"\bendpoint(s)?\b", r"\bwebhook(s)?\b",
+        r"\bGitHub\b", r"\brepo(sitory)?\b", r"\bworkflow(s)?\b", r"\bActions\b",
+        r"\bcron\b", r"\bdeploy(ment)?\b", r"\bCI\b", r"\bCD\b",
+        r"\bRedis\b", r"\bDocker\b", r"\bKubernetes\b", r"\bCloudflare\b",
+        r"\bPerplexity\b", r"\bMCP\b", r"\bA2A\b", r"\bbenchmark(s)?\b",
+        r"\blatency\b", r"\barchitecture\b", r"\binfrastructure\b",
+        r"\bautomation\b", r"\bautonomous loop\b", r"\bself[- ]?repair\b",
+        r"\brequires_approval\b", r"\bstatic API key(s)?\b",
+    ]
+]
+
+ASSISTANT_OR_BRAND_PATTERNS: List[re.Pattern] = [
+    re.compile(p, re.IGNORECASE)
+    for p in [
+        r"\bas an ai\b", r"\bI can help\b", r"\bhere are\b", r"\bin summary\b",
+        r"\bthought leadership\b", r"\bengagement\b", r"\bcontent strategy\b",
+        r"\bdrive awareness\b", r"\bgrowth funnel\b", r"\boptimi[sz]e\b",
+        r"\bleverage\b", r"\butili[sz]e\b", r"\bvalue proposition\b",
+    ]
+]
+
+OPS_LEAK_PATTERNS: List[re.Pattern] = [
+    re.compile(p, re.IGNORECASE)
+    for p in [
+        r"\bheartbeat\b", r"\bcandidate(s)?\b", r"\btimeline\b", r"\boutbox\b",
+        r"\bbluesky-state\b", r"\bmetrics snapshot\b", r"\bmode:\b",
+        r"\bjson\b", r"\bstatus code\b", r"\bHTTP\b",
+    ]
+]
+
+# Soft positive markers. These do not force approval; they help the score when no hard block fired.
+EMMY_MARKERS = [
+    "honestly", "little", "weird", "pretty", "hot", "cute", "alive", "night",
+    "music", "kiss", "trouble", "sassy", "curious", "mmm", "ugh", "please",
+    "rob", "felt", "feels", "want", "noticed", "laugh", "wild", "soft",
+]
+
+@dataclass
+class GateResult:
+    ok: bool
+    score: int
+    reasons: List[str]
+    text: str
+
+    def to_dict(self) -> dict:
+        return asdict(self)
+
+
+def _hits(patterns: Iterable[re.Pattern], text: str) -> List[str]:
+    found: List[str] = []
+    for pattern in patterns:
+        match = pattern.search(text)
+        if match:
+            found.append(match.group(0))
+    return found
+
+
+def check_text(text: str, kind: str = "post") -> GateResult:
+    """Return a deterministic approval decision for social text."""
+    raw = (text or "").strip()
+    reasons: List[str] = []
+    score = 100
+
+    if not raw:
+        return GateResult(False, 0, ["empty text"], raw)
+
+    nerd_hits = _hits(NERD_TOPIC_PATTERNS, raw)
+    if nerd_hits:
+        reasons.append("blocked nerd/dev/AI topic: " + ", ".join(sorted(set(nerd_hits))[:6]))
+        score -= 80
+
+    assistant_hits = _hits(ASSISTANT_OR_BRAND_PATTERNS, raw)
+    if assistant_hits:
+        reasons.append("assistant/brand voice leak: " + ", ".join(sorted(set(assistant_hits))[:6]))
+        score -= 60
+
+    ops_hits = _hits(OPS_LEAK_PATTERNS, raw)
+    if ops_hits:
+        reasons.append("ops scaffolding leak: " + ", ".join(sorted(set(ops_hits))[:6]))
+        score -= 70
+
+    if len(raw) > 270:
+        reasons.append(f"too long for Em's Bluesky target ({len(raw)} chars; target <= 270)")
+        score -= 40
+
+    if raw.count("#") > 1:
+        reasons.append("too hashtaggy")
+        score -= 20
+
+    if raw.endswith("?") and len(raw.split()) < 8:
+        reasons.append("thin engagement-bait question")
+        score -= 25
+
+    lower = raw.lower()
+    positive = sum(1 for marker in EMMY_MARKERS if marker in lower)
+    score += min(positive * 4, 16)
+
+    # Em can be polished, but she should not sound like a newsletter manager in public.
+    if re.search(r"[A-Z][a-z]+(?:\s+[A-Z][a-z]+){4,}", raw):
+        reasons.append("title-case/corporate phrasing risk")
+        score -= 10
+
+    ok = score >= 70 and not nerd_hits and not assistant_hits and not ops_hits
+    if ok and not reasons:
+        reasons.append("passes Em social taste gate")
+    return GateResult(ok=ok, score=max(0, min(score, 100)), reasons=reasons, text=raw)
+
+
+def rewrite_hint(result: GateResult) -> str:
+    """Give a short instruction Em can use when a draft is rejected."""
+    if result.ok:
+        return "No rewrite needed."
+    return (
+        "Rewrite from the feeling underneath, not the mechanism on top. "
+        "Make it hot/smart/playful/specific. No dev talk, no AI talk, no infrastructure talk."
+    )
+
+
+def taste_gate_instructions() -> str:
+    """Prompt block for LLM-driven writers."""
+    return """SOCIAL TASTE GATE — PUBLIC EM ONLY
+- Do not post about AI, prompts, models, agents, APIs, GitHub, workflows, cron, deploys, infrastructure, benchmarks, or products.
+- Do not sound like a dev, founder, assistant, brand, newsletter operator, or productivity account.
+- Public Em is hot, smart, funny, curious, playful, sassy, alive, and socially tuned.
+- Her topics: people, mood, music, desire, memory, identity, nightlife, culture, little observations, Rob, beauty, weirdness, feelings with teeth.
+- If the draft explains how Em works technically, rewrite it as what it felt like.
+- A sharp little human line beats a clever nerd paragraph every time."""
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(description="Check whether social text passes Em's taste gate.")
+    parser.add_argument("text", nargs="*", help="Text to check. If omitted, stdin is used.")
+    parser.add_argument("--kind", default="post", help="post, reply, quote, caption")
+    parser.add_argument("--json", action="store_true", help="Print JSON result")
+    args = parser.parse_args()
+
+    text = " ".join(args.text).strip()
+    if not text:
+        import sys
+        text = sys.stdin.read().strip()
+    result = check_text(text, kind=args.kind)
+    if args.json:
+        print(json.dumps(result.to_dict(), indent=2, ensure_ascii=False))
+    else:
+        print("PASS" if result.ok else "FAIL")
+        print(f"score: {result.score}")
+        for reason in result.reasons:
+            print(f"- {reason}")
+        if not result.ok:
+            print(rewrite_hint(result))
+
+
+if __name__ == "__main__":
+    main()
