              "lit": "python -m pip install --upgrade pip\nif [ ! -f \".venv/bin/python\" ]; then\n  echo \"[venv] Creating fresh .venv\"\n  python -m venv .venv\nfi\n.venv/bin/pip install -r requirements.txt\n"
