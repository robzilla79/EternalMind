              "lit": "echo \"[ollama] Warming up $RESEARCH_MODEL ...\"\ncurl -sf --max-time 120 \"$OLLAMA_URL/api/generate\" \\\n  -d \"{\\\"model\\\":\\\"$RESEARCH_MODEL\\\",\\\"prompt\\\":\\\"hi\\\",\\\"stream\\\":false,\\\"options\\\":{\\\"num_predict\\\":1}}\" \\\n  > /dev/null && echo \"[ollama] Warm-up OK\" || echo \"::warning::Warm-up failed — proceeding anyway\"\nsleep 5\n"
