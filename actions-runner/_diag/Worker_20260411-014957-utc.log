          {
            "key": "script",
            "value": {
              "type": 0,
              "file": 1,
              "line": 97,
              "col": 14,
              "lit": "set -e\necho \"[ollama] Pulling $RESEARCH_MODEL ...\"\nollama pull \"$RESEARCH_MODEL\"\nif [ \"$WRITER_MODEL\" != \"$RESEARCH_MODEL\" ]; then\n  echo \"[ollama] Pulling $WRITER_MODEL ...\"\n  ollama pull \"$WRITER_MODEL\"\nfi\nif [ \"$EDITOR_MODEL\" != \"$RESEARCH_MODEL\" ] && [ \"$EDITOR_MODEL\" != \"$WRITER_MODEL\" ]; then\n  echo \"[ollama] Pulling $EDITOR_MODEL ...\"\n  ollama pull \"$EDITOR_MODEL\"\nfi\nif [ \"$FALLBACK_MODEL\" != \"$RESEARCH_MODEL\" ] && [ \"$FALLBACK_MODEL\" != \"$WRITER_MODEL\" ] && [ \"$FALLBACK_MODEL\" != \"$EDITOR_MODEL\" ]; then\n  echo \"[ollama] Pulling $FALLBACK_MODEL ...\"\n  ollama pull \"$FALLBACK_MODEL\"\nfi\necho \"[ollama] Models ready:\"\nollama list\n"
            }
          }
        ]
      },
      "condition": "success() && (steps.ollama_check.outputs.reachable == 'true')",
