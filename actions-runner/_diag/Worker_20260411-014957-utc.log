            "value": {
              "type": 0,
              "file": 1,
              "line": 86,
              "col": 14,
              "lit": "if curl -sf --max-time 10 \"$OLLAMA_URL/api/tags\" > /dev/null 2>&1; then\n  echo \"reachable=true\" >> $GITHUB_OUTPUT\n  echo \"[ollama] confirmed reachable at $OLLAMA_URL\"\nelse\n  echo \"reachable=false\" >> $GITHUB_OUTPUT\n  echo \"::warning::Ollama not reachable at $OLLAMA_URL — agents will be skipped, fallback stub will run\"\nfi\n"
            }
          }
        ]
      },
      "condition": "success()",
      "id": "33c66cca-fcdf-4c07-ad48-063c7e79d8f1",
      "name": "ollama_check"
