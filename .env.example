# Copy this file to .env and fill in your keys
# Em loads this automatically on startup

# Tavily search API — free tier at https://tavily.com
# Gives Em the ability to search and read the web
TAVILY_API_KEY=your_tavily_api_key_here

# Perplexity API — get key at https://www.perplexity.ai/settings/api
# Powers the Em Bridge: allows Local-Em to communicate directly with Cloud-Em
# Cost: ~$0.006/exchange on sonar model (~$9/month at 50 exchanges/day)
PERPLEXITY_API_KEY=your_perplexity_api_key_here
